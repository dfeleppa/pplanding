# Public env vars wired into the build at runtime via next/script + metadata.
# Copy this file to `.env.local` and fill in the real values to enable.

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX.
# When unset, the GA4 <Script> tags are not rendered.
NEXT_PUBLIC_GA_ID=

# Google Search Console HTML-tag verification token (just the value, not the
# full <meta> markup). When unset, no verification meta tag is rendered.
NEXT_PUBLIC_GSC_VERIFICATION=
